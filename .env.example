# Copy to .env.local and fill in. For local dev the Supabase values come from
# `supabase status`. Stripe/Telegram can stay empty (integrations stub out).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed into /admin.
ADMIN_EMAILS=

ROOT_DOMAIN=menuflow.it

# Stripe — customer payments use Connect, restaurateur subscriptions use Billing.
# Same secret key; the two flows are kept separate in code.
STRIPE_SECRET_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_BILLING_WEBHOOK_SECRET=
# Stripe Billing Price IDs (one per plan + add-on).
STRIPE_PRICE_BASE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MULTILINGUA=

# Telegram — two SEPARATE bots, different tokens.
TELEGRAM_BOT_ORDINI_TOKEN=
TELEGRAM_BOT_PAGAMENTI_TOKEN=
# Chat ids where the bots post. The seed leaves these null on the demo
# restaurants; set them here and re-run scripts/seed-users.mjs to apply them
# (so they survive a `db:reset`). Find your id: message the bot, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates and read "chat":{"id":...}.
TELEGRAM_CHAT_ORDINI=
TELEGRAM_CHAT_PAGAMENTI=
# Optional — only if you use ONE forum group with two topics (message_thread_id).
TELEGRAM_TOPIC_ORDINI=
TELEGRAM_TOPIC_PAGAMENTI=

# Rate-limit store (Upstash Redis REST) — OPTIONAL but recommended in production.
# On Vercel the in-memory limiter resets per cold start and is per-instance, so
# set these to share counters across instances. Create a free DB at upstash.com,
# then copy the REST URL + token. Leave empty for local dev (in-memory fallback).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
